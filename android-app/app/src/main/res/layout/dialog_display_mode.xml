<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/displayModeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/priority_dialog_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/displayModeNotice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/priority_dialog_notice"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/idleModeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_mode_idle"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/idleModeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/priority_idle_only"
            android:textColor="@color/mode_idle_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/idleModeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/priority_idle_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/alwaysModeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_mode_always"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/alwaysModeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/priority_always_on"
            android:textColor="@color/mode_always_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/alwaysModeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/priority_always_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
