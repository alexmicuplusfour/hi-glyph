<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/permissionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:textSize="16sp" />

        <Button
            android:id="@+id/permissionSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="8dp"
            android:text="@string/permission_open_settings"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/configuredLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.higlyph.app.views.GlyphMatrixView
            android:id="@+id/configuredMatrixView"
            android:layout_width="match_parent"
            android:layout_height="@dimen/matrix_size_large"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:id="@+id/aodWarningContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_aod_warning"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/aodWarningTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/aod_warning_title"
                android:textColor="@color/warning_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aodWarningMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/aodWarningButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/aod_warning_open_settings"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/glyphListTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/available_glyphs"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/glyphListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
